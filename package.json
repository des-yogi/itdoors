{
  "name": "IT-Doors",
  "version": "4.5.0",
  "description": "Markup and other frontend solutions for It-Doors site",
  "author": "Igor Beliakovski",
  "license": "WTFPL",
  "repository": {
    "type": "git",
    "url": "https://github.com/des-yogi/itdoors"
  },
  "scripts": {
    "test": "npm run test:style && npm run test:js",
    "test:style": "stylelint \"src/**/*.scss\" --syntax=scss",
    "test:js": "eslint src/blocks/**/*.js src/js/**/*.js",
    "start": "gulp",
    "wlib": "cross-env BUILD_LIBRARY=yes gulp",
    "build": "gulp build",
    "lint-staged": "lint-staged"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions"
  ],
  "lint-staged": {
    "*.{js,md}": "editorconfig-cli",
    "*.{html}": "prettier --write",
    "*.scss": "stylelint --syntax=scss",
    "*.js": "eslint"
  },
  "devDependencies": {
    "@babel/core": "^7.6.2",
    "@babel/preset-env": "^7.6.2",
    "@htmlacademy/editorconfig-cli": "^1.0.0",
    "autoprefixer": "^9.6.1",
    "babel-eslint": "^10.0.3",
    "babel-loader": "^8.0.6",
    "browser-sync": "^2.26.7",
    "cpy": "^8.1.0",
    "cross-env": "^7.0.2",
    "css-mqpacker": "^7.0.0",
    "del": "^5.1.0",
    "eslint": "^7.2.0",
    "get-classes-from-html": "^1.0.1",
    "gh-pages": "^3.0.0",
    "glob-exec": "^0.1.1",
    "gulp": "^4.0.2",
    "gulp-concat": "^2.6.1",
    "gulp-csso": "^4.0.1",
    "gulp-debug": "^4.0.0",
    "gulp-file-include": "^2.2.2",
    "gulp-imagemin": "^7.1.0",
    "gulp-plumber": "^1.2.1",
    "gulp-postcss": "^8.0.0",
    "gulp-pretty-html": "^2.0.10",
    "gulp-real-favicon": "^0.3.2",
    "gulp-rename": "^2.0.0",
    "gulp-replace": "^1.0.0",
    "gulp-sass": "^4.0.1",
    "gulp-sourcemaps": "^2.6.5",
    "gulp-svgmin": "^3.0.0",
    "gulp-svgstore": "^7.0.1",
    "gulp.spritesmith": "^6.11.0",
    "husky": "^4.2.3",
    "jstransformer-markdown-it": "^2.0.0",
    "lint-staged": "^10.2.11",
    "merge-stream": "^2.0.0",
    "mkdirp": "^1.0.4",
    "path": "^0.12.7",
    "postcss-discard-comments": "^4.0.2",
    "postcss-import": "^12.0.1",
    "postcss-inline-svg": "^4.1.0",
    "postcss-object-fit-images": "^1.1.2",
    "stylelint": "^13.6.1",
    "stylelint-order": "^4.0.0",
    "stylelint-selector-bem-pattern": "^2.1.0",
    "through2": "^3.0.1",
    "vinyl-buffer": "^1.0.1",
    "webpack": "^4.41.0",
    "webpack-stream": "^5.2.1"
  },
  "dependencies": {
    "autosize": "^4.0.2",
    "blazy": "^1.8.2",
    "bootstrap": "^4.5.0",
    "choices.js": "^9.0.1",
    "closest": "0.0.1",
    "jquery": "^3.5.1",
    "jquery-sticky": "^1.0.4",
    "object-fit-images": "^3.2.4",
    "picturefill": "^3.0.3",
    "smoothscroll-for-websites": "^1.4.10",
